# ============================================================================
# COMID — environment template
# ============================================================================
# Copy this file to ``.env`` (git-ignored) and fill in the values for your
# machine. See docs/USER_MANUAL.md (section 2) for what each variable means.

# --- Database ---------------------------------------------------------------
# Leave unset to use a local SQLite database. Set a URL to use PostgreSQL.
# DATABASE_URL=postgresql://user:pass@localhost/comid_db

# --- LAMMPS executable (custom GPU build required) --------------------------
# Set automatically by ./install.sh --full (or scripts/install_lammps.sh).
# LAMMPS_EXECUTABLE=/path/to/lammps/build/lmp
# LAMMPS_GPU_PACKAGE=kokkos

# --- Celery (distributed jobs) ----------------------------------------------
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- Experiment / force-field cache paths -----------------------------------
# FF_CACHE_DIR=~/.comid/ff_cache
# EXPERIMENT_BASE_DIR=/data/experiments

# ============================================================================
# Admin control flag
# ============================================================================
# Set to 1 to enable the admin-only force-field endpoints/UI:
#   - GET  /artifacts/admin/capabilities   (always 200; reports enabled state)
#   - GET  /artifacts/admin/status         (404 when this flag is 0)
#   - GET  /artifacts/admin/batch-progress (404 when this flag is 0)
#   - POST /artifacts/admin/generate/{mol_id}?profile=baseline|sqm_robust
#   - POST /artifacts/admin/generate-all?profile=...
#   - POST /artifacts/admin/diagnose/{mol_id}
#
# The CLI batch tool (scripts/generate_gaff2_artifact.py) is gated by this flag
# as well. Default for local development is 0 (disabled).
ASPHALT_ANTECHAMBER_ADMIN=0

# Ionic force-field profile activation (separate gate).
# ASPHALT_IONIC_ROUTE_ACTIVATED=0

# Data-sync NAS backup/load root (NAS features are disabled when unset).
# DATA_SYNC_NAS_ROOT=/mnt/nas/comid_backups
